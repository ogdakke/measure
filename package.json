{
  "name": "@ogdakke/measure",
  "version": "0.1.1",
  "description": "Measure and compare command execution times across machines",
  "homepage": "https://github.com/ogdakke/measure",
  "license": "MIT",
  "author": {
    "name": "Daniel Wargh",
    "email": "dw@danielwargh.com",
    "url": "https://danielwargh.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ogdakke/measure.git"
  },
  "bin": {
    "measure": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "os": [
    "darwin",
    "win32"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "lint": "oxlint",
    "lint:all": "oxlint --type-aware --type-check",
    "fmt": "oxfmt .",
    "prepack": "bun run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish && git push --follow-tags"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@typescript/native-preview": "^7.0.0-dev.20260412.1",
    "better-result": "^2.8.2",
    "ink": "7",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "react": "^19.2.0"
  },
  "engines": {
    "bun": ">=1.3.12"
  },
  "readme": "README.md",
  "dependencies": {
    "fzf": "^0.5.2",
    "ink-spinner": "^5.0.0"
  }
}
